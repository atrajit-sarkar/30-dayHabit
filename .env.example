# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_bot_token_here

# Firebase Credentials — use ONE of these two methods:

# Method 1: File path (easier for local development)
FIREBASE_CREDENTIALS_FILE=./serviceAccountKey.json

# Method 2: Inline JSON string (for Railway deployment)
# FIREBASE_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Timezone for polls (default: Asia/Kolkata = 10 PM IST)
TIMEZONE=Asia/Kolkata
